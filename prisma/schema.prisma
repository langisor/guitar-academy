generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              Int      @id @default(autoincrement())
  username        String   @unique
  email           String   @unique
  passwordHash    String
  xp              Int      @default(0)
  streak          Int      @default(0)
  lastPracticeDate DateTime?
  dailyGoal       Int      @default(15)
  createdAt       DateTime @default(now())
  progress        UserProgress[]
  practiceSessions PracticeSession[]
  dailyGoals      DailyGoal[]
}

model Course {
  id          Int     @id @default(autoincrement())
  title       String
  language    String
  description String?
  createdAt   DateTime @default(now())
  worlds      World[]
}

model World {
  id           Int     @id @default(autoincrement())
  courseId     Int
  title        String
  description String?
  icon         String  @default("music")
  orderIndex   Int
  isLocked    Boolean @default(true)
  course      Course  @relation(fields: [courseId], references: [id])
  levels      Level[]
}

model Level {
  id           Int     @id @default(autoincrement())
  worldId      Int
  title        String
  description String?
  contentPath  String?
  difficulty  String  @default("easy")
  xpReward    Int     @default(50)
  orderIndex  Int
  isLocked   Boolean @default(true)
  world       World   @relation(fields: [worldId], references: [id])
  exercises  Exercise[]
  userProgress UserProgress[]
}

model Exercise {
  id            Int     @id @default(autoincrement())
  levelId       Int
  type          String
  question     String
  options      String?
  correctAnswer String?
  data         String?
  xpReward     Int     @default(10)
  orderIndex   Int
  level        Level   @relation(fields: [levelId], references: [id])
}

model Song {
  id         Int     @id @default(autoincrement())
  title     String
  artist    String
  chords    String
  difficulty String  @default("easy")
  tempo      Int     @default(80)
  capo      Int     @default(0)
  tuning    String   @default("standard")
}

model UserProgress {
  id          Int      @id @default(autoincrement())
  userId      Int
  levelId     Int
  completed  Boolean  @default(false)
  stars       Int      @default(0)
  xpEarned    Int      @default(0)
  attempts    Int      @default(0)
  completedAt DateTime?
  user       User     @relation(fields: [userId], references: [id])
  level      Level    @relation(fields: [levelId], references: [id])

  @@unique([userId, levelId])
}

model PracticeSession {
  id                Int      @id @default(autoincrement())
  userId            Int
  durationMinutes   Int
  exercisesCompleted Int      @default(0)
  xpEarned         Int      @default(0)
  date            DateTime  @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model DailyGoal {
  id             Int      @id @default(autoincrement())
  userId         Int
  date           DateTime
  minutesPracticed Int     @default(0)
  goalMinutes    Int      @default(15)
  completed     Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}